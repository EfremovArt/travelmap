  // Получение информации об авторе поста
  Future<Map<String, dynamic>> _getPostAuthorInfo(Post post) async {
    if (_isCurrentUserPost(post)) {
      // Если пост принадлежит текущему пользователю, возвращаем данные текущего пользователя
      return {
        'firstName': _userFullName.split(' ').first,
        'lastName': _userFullName.split(' ').length > 1 ? _userFullName.split(' ').last : '',
        'profileImageUrl': _userProfileImage,
      };
    }

    // Иначе получаем информацию о пользователе по ID через API
    final userData = await UserService.getUserInfoById(post.user);
    return userData;
  }

  /// Показать модальное окно с комментариями
  void _showCommentsModal(Post post) {
    // Показываем комментарии в модальном окне снизу
    showModalBottomSheet(
      context: context,
      isScrollControlled: true, // Важно для правильного отображения клавиатуры
      backgroundColor: Colors.transparent,
      builder: (context) {
        return Container(
          height: MediaQuery.of(context).size.height * 0.75,
          decoration: BoxDecoration(
            color: Colors.white,
            borderRadius: BorderRadius.only(
              topLeft: Radius.circular(20),
              topRight: Radius.circular(20),
            ),
          ),
          child: CommentsScreen(
            photoId: post.id,
            photoUrl: post.imageUrls.isNotEmpty
                ? post.imageUrls.first
                : (post.images.isNotEmpty
                ? post.images.first.path
                : 'https://via.placeholder.com/300'),
          ),
        );
      },
    );
  }

  // Показать пост на карте - модифицированный метод
  void _showOnMap(Post post) {
    if (post.location == null) {
      AppLogger.log("❌ Невозможно показать пост на карте: отсутствуют координаты");
      return;
    }
    
    AppLogger.log("📍 Показываем пост ${post.id} на карте с координатами ${post.location!.latitude}, ${post.location!.longitude}");
    
    // Check the annotation processing lock FIRST
    if (_isProcessingAnnotations) {
        AppLogger.log("⚠️ Cannot show post on map, annotation processing is already in progress.");
        return; // Exit if another annotation operation is running
    }

    // Устанавливаем флаг, что показываем конкретный пост
    _showingSpecificPost = true;
    
    // Сохраняем пост для дальнейшего использования
    _lastViewedPost = post;
    _lastViewedPostIndex = _posts.indexWhere((p) => p.id == post.id);
    if (_lastViewedPostIndex == -1) {
      AppLogger.log("⚠️ Пост не найден в списке, индекс установлен в -1");
    }

    _updateCameraOptions();

    setState(() {
      _activeView = 'map';
    });
    
    Future.delayed(Duration(milliseconds: 300), () async {
      if (!mounted || _mapboxMap == null) { 
         AppLogger.log("❌ Карта недоступна после переключения вида");
         _showingSpecificPost = false; // Reset flag on exit
         return; 
      }
      
      // Убедимся, что post всё еще нужный объект (проверка данных)
      AppLogger.log("🔍 Проверка данных поста перед отображением: ID=${post.id}, координаты=${post.location!.latitude},${post.location!.longitude}");
      
      // Set the processing lock
      if (mounted) _isProcessingAnnotations = true;

      try {
        AppLogger.log("🎯 Отображаем маркер конкретно для поста: ${post.id}");
        
         // --- Replace deleteAll with manager recreation ---
        try {
            AppLogger.log("🔄 Recreating annotation manager instead of deleteAll in _showOnMap");
            final annotations = await _mapboxMap!.annotations;
            _pointAnnotationManager = await annotations.createPointAnnotationManager();
             // Re-add listener to the new manager
            _pointAnnotationManager?.addOnPointAnnotationClickListener(_markerClickListener);
            AppLogger.log("✅ New annotation manager created in _showOnMap");
            _markerPostMap = {}; // Clear the Dart-side map as well
        } catch (e) {
            AppLogger.log("❌ Error recreating annotation manager in _showOnMap: $e");
            // Don't reset _showingSpecificPost here, let finally handle it
            if(mounted) _isProcessingAnnotations = false; // Release lock on error
            _showingSpecificPost = false; // Reset flag on error
            return; // Exit if we can't get a manager
        }
        
        // Создаем новую карту для соответствий маркеров и постов
        final Map<String, Post> newMarkerPostMap = {};
        
        // Создаем точку для маркера с проверкой данных
        final point = Point(
          coordinates: Position(
            post.location!.longitude, 
            post.location!.latitude
          )
        );
        AppLogger.log("📌 Создаем точку с координатами: ${point.coordinates.lng}, ${point.coordinates.lat}");
        
        // Получаем текущий zoom карты (вместо принудительной установки zoom: 15.0)
        double currentZoom = 15.0; // Значение по умолчанию, если не удастся получить текущий zoom
        try {
          final cameraState = await _mapboxMap!.getCameraState();
          if (cameraState != null) {
            currentZoom = cameraState.zoom;
            AppLogger.log("📏 Текущий zoom карты: $currentZoom");
          }
        } catch (e) {
          AppLogger.log("⚠️ Не удалось получить текущий zoom карты: $e");
        }
        
        // Переместим камеру к нужной локации, сохраняя текущий zoom
        await _mapboxMap!.flyTo(
          CameraOptions(
            center: point,
            zoom: currentZoom, // Используем текущий zoom вместо фиксированного значения
            pitch: 30.0,
          ),
          MapAnimationOptions(duration: 1000),
        );
        AppLogger.log("🔍 Камера перемещена к координатам: ${point.coordinates.lng}, ${point.coordinates.lat} с сохранением zoom: $currentZoom");
        
        // Создаем маркер для указанного поста
        try {
          // Получаем ID для изображения маркера
          String markerImageId = "marker-15"; // Default fallback
          if (post.imageUrls.isNotEmpty) {
            String imageUrl = post.imageUrls.first;
            if (!imageUrl.startsWith("http")) {
              if (imageUrl.startsWith("/")) imageUrl = imageUrl.substring(1);
              imageUrl = "${ApiConfig.baseUrl}/${imageUrl}";
            }
            
            final String cacheId = "post-marker-${post.id}";
            AppLogger.log("🖼️ Attempting to use image for marker: $cacheId with URL: $imageUrl");
            
            // Проверяем, есть ли изображение уже в стиле карты
            bool existsInStyle = false;
            try {
              existsInStyle = await _mapboxMap!.style.hasStyleImage(cacheId);
              AppLogger.log("🔍 Image exists in style? $existsInStyle");
            } catch (e) {
              AppLogger.log("⚠️ Ошибка проверки наличия изображения в стиле: $e");
            }
            
            if (existsInStyle) {
              markerImageId = cacheId;
              AppLogger.log("✅ Используем существующее изображение из стиля: $cacheId");
            } else if (MapboxConfig.markerImageBytesCache.containsKey(cacheId)) {
              // Если есть в кэше, регистрируем
              AppLogger.log("🖼️ Изображение есть в кэше, регистрируем: $cacheId");
              try {
                markerImageId = await MapboxConfig.registerPostImageAsMarker(
                  _mapboxMap!,
                  MapboxConfig.markerImageBytesCache[cacheId]!,
                  post.id
                );
                AppLogger.log("✅ Зарегистрировано изображение из кэша: $markerImageId");
              } catch (e) {
                AppLogger.log("❌ Ошибка регистрации изображения из кэша: $e");
                markerImageId = "marker-15";
              }
            } else {
              // Загружаем и регистрируем новое изображение
              AppLogger.log("🔄 Загружаем изображение с URL: $imageUrl");
              try {
                final http.Response response = await http.get(Uri.parse(imageUrl));
                if (response.statusCode == 200) {
                  final Uint8List imageBytes = response.bodyBytes;
                  markerImageId = await MapboxConfig.registerPostImageAsMarker(
                    _mapboxMap!,
                    imageBytes,
                    post.id
                  );
                  AppLogger.log("✅ Загружено и зарегистрировано новое изображение: $markerImageId");
                  
                  // Сохраняем в кэш для будущего использования
                  MapboxConfig.markerImageBytesCache[cacheId] = imageBytes;
                } else {
                  AppLogger.log("⚠️ Не удалось загрузить изображение, код: ${response.statusCode}");
                  markerImageId = "marker-15";
                }
              } catch (e) {
                AppLogger.log("❌ Ошибка загрузки изображения: $e");
                markerImageId = "marker-15";
              }
            }
          }
          
          // Создаем опции для маркера
          final options = PointAnnotationOptions(
            geometry: point,
            iconSize: 0.6, // Увеличенный размер для выделения (уменьшен в 2 раза)
            iconImage: markerImageId,
            textField: post.locationName,
            textSize: 14.0, // Увеличенный текст
            textOffset: [0, 3.0],
            textColor: 0xFF000000,
            textHaloColor: 0xFFFFFFFF,
            textHaloWidth: 2.0,
            iconOffset: [0, 0],
          );
          
          AppLogger.log("🎨 Создаем маркер с изображением: ${options.iconImage}, размер: ${options.iconSize}");
          
          // Создаем маркер
          final annotation = await _pointAnnotationManager?.create(options);
          if (annotation != null) {
            newMarkerPostMap[annotation.id] = post;
            AppLogger.log("✅ Создан маркер с ID: ${annotation.id} для поста ${post.id}");
          } else {
            AppLogger.log("⚠️ Не удалось создать маркер, результат null");
          }
        } catch (e) {
          AppLogger.log("❌ Ошибка создания маркера для поста ${post.id}: $e");
        }
        
        // Обновляем карту маркеров
        _markerPostMap = newMarkerPostMap;
        
      } catch (e) {
        AppLogger.log("❌ Ошибка при (_showOnMap) отображении поста на карте: $e");
        if (mounted) _showingSpecificPost = false; // Reset flag on error
      } finally {
        // Release lock
        if (mounted) {
           _isProcessingAnnotations = false;
        }
         AppLogger.log("🏁 Завершение _showOnMap, флаг _isProcessingAnnotations сброшен");
      }
    });
  }

  // Метод для визуального выделения маркера без создания нового
  void _tryHighlightMarkerVisually(Post post) {
    AppLogger.log("🎨 Попытка визуально выделить маркер поста ${post.id} без показа окна");
    
    // Здесь можно добавить логику для визуального выделения маркера
    // Например, анимировать блинк для маркера или изменить его цвет
    // Но сейчас просто оставляем эту функцию как заглушку
  }

  // Метод для добавления выделенного маркера поверх других
  Future<void> _addHighlightedMarker(Post post) async {
    if (_mapboxMap == null || _pointAnnotationManager == null) return;
    
    try {
      // Создаем точку для маркера
      final point = Point(
        coordinates: Position(
          post.location.longitude, 
          post.location.latitude
        )
      );
      
      // Проверяем наличие фото-маркера для этого поста
      final String markerImageId = "post-marker-${post.id}";
      final bool hasImage = await _mapboxMap!.style.hasStyleImage(markerImageId);
      final iconId = hasImage ? markerImageId : "marker-15";
      
      AppLogger.log("🔍 Добавляем выделенный маркер для поста ${post.id}. Фото: ${hasImage ? 'Есть' : 'Нет'}");
      
      // Создаем опции для выделенного маркера
      final options = PointAnnotationOptions(
        geometry: point,
        iconSize: 0.75, // Увеличенный размер для выделения (уменьшен в 2 раза)
        iconImage: iconId,
        textField: post.locationName,
        textSize: 14.0, // Увеличенный текст для выделения
        textOffset: [0, 3.0],
        textColor: 0xFF000000,
        textHaloColor: 0xFFFFFFFF,
        textHaloWidth: 2.0,
        iconOffset: [0, 0],
        iconAnchor: IconAnchor.CENTER,
      );
      
      // Добавляем маркер на карту
      final annotation = await _pointAnnotationManager!.create(options);
      
      // Сохраняем соответствие для нового маркера
      if (annotation != null) {
        _markerPostMap[annotation.id] = post;
        AppLogger.log("✅ Создан выделенный маркер для поста ${post.id}");
      }
    } catch (e) {
      AppLogger.log("❌ Ошибка при создании выделенного маркера: $e");
    }
  }

  // Метод для редактирования поста
  void _editPost(Post post) {
    Navigator.push<dynamic>(
      context,
      MaterialPageRoute(
        builder: (context) => EditPostScreen(post: post),
      ),
    ).then((result) {
      if (result != null) {
        // Если пост был обновлен, обновляем данные и обновляем UI
        if (result is Post) {
          // Обновляем пост в локальном списке
          final index = _posts.indexWhere((p) => p.id == post.id);
          if (index != -1) {
            setState(() {
              _posts[index] = result;
              
              // Если у нас есть выбранный пост и это тот, который мы обновили
              if (_selectedPost != null && _selectedPost!.id == post.id) {
                _selectedPost = result;
              }
            });
          }
        }
        // В любом случае обновляем посты
        _loadAllPosts();
      }
    });
  }

  /// View post details
  void _openPostDetails(Post post) {
    // Navigation to post details screen should be here

    // Close details in current view
    setState(() {
      _selectedPost = null;
    });

    // Navigate to details screen (placeholder)
    // TODO: Add actual navigation to post details screen
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text('Viewing details for post ${post.locationName}'),
        duration: const Duration(seconds: 2),
      ),
    );
  }

  /// Удаляет пост из системы
  Future<void> _deletePost(Post post) async {
    // Показываем диалог подтверждения
    final bool? shouldDelete = await showDialog<bool>(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('Delete post?'),
        content: const Text('This post will be permanently deleted. Continue?'),
        actions: [
          TextButton(
            onPressed: () => Navigator.of(context).pop(false),
            child: const Text('Cancel'),
          ),
          TextButton(
            onPressed: () => Navigator.of(context).pop(true),
            child: const Text('Delete', style: TextStyle(color: Colors.red)),
          ),
        ],
      ),
    );

    // Если пользователь подтвердил удаление
    if (shouldDelete == true) {
      try {
        // Показываем индикатор загрузки
        if (mounted) {
          ScaffoldMessenger.of(context).showSnackBar(
            const SnackBar(
              content: Text('Удаление поста...'),
              duration: Duration(seconds: 1),
            ),
          );
        }

        // Удаляем пост через сервис
        final bool success = await PostService.deletePost(post.id);

        if (!success) {
          throw Exception("Сервер вернул ошибку при удалении поста");
        }

        // Обновляем список постов
        await _loadAllPosts();

        // Если открыт этот пост в деталях, закрываем детали
        if (_selectedPost?.id == post.id) {
          setState(() {
            _selectedPost = null;
          });
        }

        // Показываем сообщение об успешном удалении
        if (mounted) {
          ScaffoldMessenger.of(context).showSnackBar(
            const SnackBar(
              content: Text('Пост успешно удален'),
            ),
          );
        }
      } catch (e) {
        AppLogger.log("Ошибка при удалении поста: $e");

        // Показываем сообщение об ошибке
        if (mounted) {
          ScaffoldMessenger.of(context).showSnackBar(
            SnackBar(
              content: Text('Ошибка при удалении поста. Пожалуйста, попробуйте снова позже.'),
              backgroundColor: Colors.red,
            ),
          );
        }

        // Всё равно обновляем список постов на случай, если пост был удалён, но произошла ошибка при получении ответа
        try {
          await _loadAllPosts();
        } catch (refreshError) {
          AppLogger.log("Ошибка при обновлении списка постов после ошибки удаления: $refreshError");
        }
      }
    }
  }

  /// Initialize location service
  Future<void> _initializeLocationService() async {
    AppLogger.log("Initializing location service");

    try {
      // Check location permissions
      bool hasPermission = await _checkLocationPermission();

      if (!hasPermission) {
        AppLogger.log("No permission to access location");
        return;
      }

      // Всегда определяем текущее местоположение для кнопки "Моя геолокация"
      AppLogger.log("Определяем текущее местоположение...");
      // Get current position
      geo.Position position = await geo.Geolocator.getCurrentPosition(
        desiredAccuracy: geo.LocationAccuracy.high,
        timeLimit: const Duration(seconds: 10),
      );

      AppLogger.log("Current position obtained: ${position.latitude}, ${position.longitude}");

      if (mounted) {
        setState(() {
          _currentPosition = GeoLocation(
              latitude: position.latitude,
              longitude: position.longitude
          );
        });
      }
    } catch (e) {
      AppLogger.log("Error initializing location service: $e");
      if (mounted) {
        setState(() {
          _error = "Error getting current position: $e";
        });
      }
    }
  }

  /// Properly cleans up all map-related resources (Now Async and Safe)
  Future<void> _cleanupMapResources() async { // Make async
    // Check if mounted
    if (!mounted) {
      AppLogger.log("Widget unmounted, skipping map resource cleanup in HomeTab.");
      return;
    }

    // Check and set lock flag
    if (_isProcessingAnnotations) {
      AppLogger.log("⚠️ Annotation processing already in progress, skipping _cleanupMapResources in HomeTab");
      return;
    }
     // No need for setState here unless UI depends on this flag immediately
     _isProcessingAnnotations = true; 

    if (_mapboxMap != null) {
      try {
        AppLogger.log("Cleaning up map resources in HomeTab");

        // Safely remove the annotation manager
        if (_pointAnnotationManager != null) {
          try {
            // Check again before await, as state might change
            if (!mounted || _mapboxMap == null) {
                 _isProcessingAnnotations = false; // Release lock if check fails
                 return; 
            }
            AppLogger.log("🧹 Attempting to remove annotation manager in HomeTab cleanup...");
            await _mapboxMap!.annotations.removeAnnotationManager(_pointAnnotationManager!);
            AppLogger.log("🧹 Annotation manager removed successfully in HomeTab cleanup");
             // Set to null only after successful removal and if still mounted
            if (mounted) {
                _pointAnnotationManager = null;
            }
          } catch (e) {
            AppLogger.log("🔴 Error while clearing annotations during HomeTab cleanup: $e");
            // Still try to nullify if mounted
             if (mounted) {
                _pointAnnotationManager = null;
             }
          }
        }
        
        // Release map instance *after* potentially async operations
        if (mounted) {
            _mapboxMap = null;
            _isMapLoaded = false; // Set map loaded to false
            AppLogger.log("🗺️ MapboxMap instance released for HomeTab");
        }

      } catch (e) {
        AppLogger.log("🔴 Error while cleaning up map resources in HomeTab: $e");
        // Attempt cleanup even on error
        if (mounted) {
            _pointAnnotationManager = null;
            _mapboxMap = null;
            _isMapLoaded = false;
        }
      } finally {
         // Release lock flag
         if (mounted) {
           _isProcessingAnnotations = false; 
         }
      }
    } else {
        // Map was already null
        if (mounted) {
            _pointAnnotationManager = null;
            _isMapLoaded = false; // Ensure loaded is false
        }
        // Release lock if map was already null
         if (mounted) { // Check mounted before state change
            _isProcessingAnnotations = false;
         }
    }
  }

  /// Перезагружает стиль карты и маркеры
  Future<void> _reloadMapStyleAndMarkers() async {
    if (_mapboxMap == null) return;
    
    // Проверяем флаг _showingSpecificPost
    if (_showingSpecificPost) {
      AppLogger.log("⚠️ Пропускаем перезагрузку стиля карты и маркеров, так как показывается конкретный пост");
      return;
    }
    
    try {
      AppLogger.log("🔄 Reloading map style and markers");

      // Предварительно загружаем все стандартные маркеры
      await MapboxConfig.registerMapboxMarkerImages(_mapboxMap!);
      AppLogger.log("✅ Default markers registered");

      // Восстанавливаем все кэшированные изображения маркеров
      await MapboxConfig.reinstallCachedMarkerImages(_mapboxMap!);
      AppLogger.log("✅ Cached marker images reinstalled");
      
      // Перезагружаем список постов перед восстановлением маркеров
      await _loadAllPosts();
      AppLogger.log("✅ Posts reloaded before marker restoration");
      
      // Создаем новый менеджер аннотаций и загружаем маркеры
      try {
        final annotations = await _mapboxMap!.annotations;
        _pointAnnotationManager = await annotations.createPointAnnotationManager();
        _pointAnnotationManager?.addOnPointAnnotationClickListener(_markerClickListener);
        AppLogger.log("✅ Created new annotation manager for marker reload");
      } catch (e) {
        AppLogger.log("❌ Error creating annotation manager: $e");
      }
      
      // Заново загружаем маркеры постов
      await _loadPostMarkers();
      AppLogger.log("✅ Post markers reloaded");

      AppLogger.log("✅ Map style and markers reloaded successfully");
    } catch (e) {
      AppLogger.log("❌ Error reloading map style and markers: $e");
      
      // Даже при ошибке пытаемся загрузить маркеры
      try {
        if (_mapboxMap != null && mounted) {
          await _loadPostMarkers();
          AppLogger.log("✅ Marker loading attempted after style error");
        }
      } catch (innerError) {
        AppLogger.log("❌ Error in fallback marker loading: $innerError");
      }
    }
  }
  
  // Загрузка стиль карты
  Future<void> _loadMapStyle() async {
    if (_mapboxMap == null) return;
    
    try {
      // Устанавливаем стиль карты
      await _mapboxMap!.loadStyleURI(MapboxConfig.DEFAULT_STYLE_URI);
      
      // Обновляем состояние
      setState(() {
        _isMapLoaded = true;
        _isMapLoading = false;
      });
    } catch (e) {
      AppLogger.log("Ошибка при загрузке стиля карты: $e");
      setState(() {
        _isMapLoaded = false;
        _isMapLoading = false;
        _error = e.toString();
      });
    }
  }

  /// Запускает таймер обновления постов
  void _startPostsRefreshTimer() {
    _postsRefreshTimer?.cancel();
    _postsRefreshTimer = Timer.periodic(const Duration(seconds: 10), (_) {
      AppLogger.log("📱 Executing scheduled post refresh");
      _loadAllPosts();
    });

    // Начальное обновление
    _loadAllPosts();

    AppLogger.log("⏱️ Post refresh timer started: every 10 seconds");
  }

  // Загрузка данных пользователя
  Future<void> _loadUserData() async {
    try {
      final fullName = await UserService.getFullName();
      final profileImage = await UserService.getProfileImage();
      final email = await UserService.getEmail();
      final userId = await UserService.getUserId(); // Получаем ID пользователя

     if (mounted) {
        setState(() {
          _userFullName = fullName;
          _userProfileImage = profileImage;
          _userEmail = email;
          _userId = userId; // Сохраняем ID пользователя
          _userDataLoaded = true;
        });
      }
    } catch (e) {
      AppLogger.log("Error loading user data: $e");
    }
  }

  /// Метод для построения основного контента в зависимости от активной вкладки
  Widget _buildMainContent() {
    AppLogger.log('⭐⭐⭐ _buildMainContent ВЫЗВАН, АКТИВНЫЙ ВИД: $_activeView ⭐⭐⭐');
    AppLogger.log('⭐⭐⭐ ТЕКУЩИЕ НАСТРОЙКИ КАМЕРЫ: center=${_lastCameraOptions?.center?.coordinates.lng},${_lastCameraOptions?.center?.coordinates.lat} zoom=${_lastCameraOptions?.zoom} ⭐⭐⭐');

    // Если активна вкладка карты
    if (_activeView == 'map') {
      // Если есть сохраненные настройки камеры или текущее местоположение
      if (_lastCameraOptions != null || _currentPosition != null) {
        return Stack(
          children: [
            SizedBox(
              width: MediaQuery.of(context).size.width,
              height: MediaQuery.of(context).size.height,
              child: MapWidget(
                key: const ValueKey("mapWidget"),
                onMapCreated: _onMapCreated,
                styleUri: MapboxConfig.DEFAULT_STYLE_URI,
                // Используем сохраненные настройки камеры, или значения по умолчанию из текущего местоположения, если их нет
                cameraOptions: _lastCameraOptions ?? (_currentPosition != null ? CameraOptions(
                    center: Point(
                        coordinates: Position(
                            _currentPosition!.longitude,
                            _currentPosition!.latitude
                        )
                    ),
                    zoom: 12.0
                ) : null), // Если нет ни сохраненных настроек, ни текущего местоположения, то null
                onTapListener: (context) {
                  // Убираем выбранный пост при нажатии на пустое место карты
                  setState(() {
                    _selectedPost = null;
                  });
                },
              ),
            ),
            // Добавляем пульсирующую точку, если есть текущее местоположение
            if (_currentPosition != null && _mapboxMap != null && !_isMapLoading)
              _buildPulsingUserLocationMarker(),
          ],
        );
      } else {
        // Если нет ни сохраненных настроек, ни текущего местоположения, показываем индикатор загрузки
        return const Center(
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                CircularProgressIndicator(),
                SizedBox(height: 16),
                Text("Определение местоположения...", style: TextStyle(color: Colors.grey))
              ],
            )
        );
      }
    }

    // Если активна вкладка ленты
    return _buildFeedContent();
  }

  /// Создает пульсирующий маркер для отображения текущего местоположения пользователя
  Widget _buildPulsingUserLocationMarker() {
    return StreamBuilder<ScreenCoordinate?>(
      stream: Stream.periodic(const Duration(milliseconds: 100))
          .asyncMap((_) => _getScreenCoordinatesForLocation(_currentPosition!)),
      builder: (context, snapshot) {
        if (!snapshot.hasData || snapshot.data == null) {
          return const SizedBox.shrink(); // Если координаты еще не готовы, ничего не отображаем
        }

        final screenCoordinate = snapshot.data!;

        return Positioned(
          left: screenCoordinate.x.toDouble() - 15,
          top: screenCoordinate.y.toDouble() - 15,
          child: AnimatedBuilder(
            animation: _pulseAnimation,
            builder: (context, child) {
              return Stack(
                alignment: Alignment.center,
                children: [
                  // Внешний пульсирующий круг
                  Container(
                    width: 30 + (10 * _pulseAnimation.value),
                    height: 30 + (10 * _pulseAnimation.value),
                    decoration: BoxDecoration(
                      shape: BoxShape.circle,
                      color: Colors.blue.withOpacity(0.3 * (1 - _pulseAnimation.value)),
                    ),
                  ),
                  // Средний круг
                  Container(
                    width: 20,
                    height: 20,
                    decoration: BoxDecoration(
                      shape: BoxShape.circle,
                      color: Colors.blue.withOpacity(0.5),
                    ),
                  ),
                  // Внутренний круг
                  Container(
                    width: 10,
                    height: 10,
                    decoration: const BoxDecoration(
                      shape: BoxShape.circle,
                      color: Colors.blue,
                    ),
                  ),
                ],
              );
            },
          ),
        );
      },
    );
  }

  /// Преобразует геокоординаты в координаты экрана
  Future<ScreenCoordinate?> _getScreenCoordinatesForLocation(GeoLocation location) async {
    if (_mapboxMap == null) return null;

    try {
      final coordinate = await _mapboxMap!.pixelForCoordinate(
        Point(
          coordinates: Position(
            location.longitude,
            location.latitude,
          ),
        ),
      );
      return coordinate;
    } catch (e) {
      AppLogger.log('Error converting geo coordinates to screen coordinates: $e');
      return null;
    }
  }

  /// Строит содержимое ленты постов
  Widget _buildFeedContent() {
    AppLogger.log('⭐⭐⭐ ВЫЗОВ _buildFeedContent, АКТИВНЫЙ ВИД: $_activeView ⭐⭐⭐');

    if (_posts.isEmpty) {
      // Отображаем заглушку, если нет постов
      return Center(
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Icon(
              Icons.photo_album,
              size: 80,
              color: Colors.grey[400],
            ),
            const SizedBox(height: 16),
            Text(
              'Пока нет постов',
              style: TextStyle(
                fontSize: 18,
                fontWeight: FontWeight.bold,
                color: Colors.grey[700],
              ),
            ),
            const SizedBox(height: 8),
            Padding(
              padding: const EdgeInsets.symmetric(horizontal: 32),
              child: Text(
                'Здесь будут отображаться посты от вас и людей, на которых вы подписаны',
                textAlign: TextAlign.center,
                style: TextStyle(
                  color: Colors.grey[600],
                ),
              ),
            ),
          ],
        ),
      );
    }

    AppLogger.log('🔄 _buildFeedContent: total posts loaded: ${_posts.length}');
    AppLogger.log('⭐⭐⭐ НАЧИНАЕМ ГРУППИРОВКУ ПОСТОВ ПО ЛОКАЦИЯМ ⭐⭐⭐');

    // Группируем посты по локациям
    final Map<String, List<Post>> postsByLocation = {};
    final Set<String> processedPosts = {};

    // Функция для вычисления расстояния между двумя координатами в метрах
    double calculateDistance(double lat1, double lon1, double lat2, double lon2) {
      const int earthRadius = 6371000; // радиус Земли в метрах
      final double phi1 = lat1 * pi / 180;
      final double phi2 = lat2 * pi / 180;
      final double deltaPhi = (lat2 - lat1) * pi / 180;
      final double deltaLambda = (lon2 - lon1) * pi / 180;

      final double a = sin(deltaPhi / 2) * sin(deltaPhi / 2) +
          cos(phi1) * cos(phi2) *
              sin(deltaLambda / 2) * sin(deltaLambda / 2);
      final double c = 2 * atan2(sqrt(a), sqrt(1 - a));

      return earthRadius * c; // Расстояние в метрах
    }

    // Группируем посты, находящиеся в пределах 200 метров друг от друга
    for (var post in _posts) {
      if (processedPosts.contains(post.id)) continue;

      // Ищем ближайшую существующую группу для поста
      String? closestGroup;
      double minDistance = double.infinity;

      for (var locationKey in postsByLocation.keys) {
        // Берем первый пост из группы для сравнения координат
        final firstPost = postsByLocation[locationKey]!.first;

        // Проверяем также имя локации
        bool sameName = firstPost.locationName.toLowerCase() == post.locationName.toLowerCase();

        // Считаем расстояние между текущим постом и первым постом группы
        final distance = calculateDistance(
            post.location.latitude, post.location.longitude,
            firstPost.location.latitude, firstPost.location.longitude
        );

        AppLogger.log('🧮🧮🧮 Сравниваем пост ${post.id} (${post.locationName}) с группой $locationKey');
        AppLogger.log('📏📏📏 Расстояние: ${distance.toStringAsFixed(2)}м, Одинаковые имена: $sameName');

        // Добавляем пост в группу если одинаковые имена ИЛИ расстояние меньше 200 метров
        if ((sameName || distance <= 200) && distance < minDistance) {
          closestGroup = locationKey;
          minDistance = distance;
          AppLogger.log('✅✅✅ Нашли подходящую группу! Группа: $locationKey, Расстояние: ${minDistance.toStringAsFixed(2)}м');
        }
      }

      if (closestGroup != null) {
        // Если нашли ближайшую группу, добавляем пост к ней
        postsByLocation[closestGroup]!.add(post);
        AppLogger.log('🔄 Post ${post.id} added to existing location group $closestGroup, distance: ${minDistance.toStringAsFixed(2)}m');
      } else {
        // Иначе создаем новую группу с этим постом
        final newLocationKey = '${post.locationName}-${post.id}';
        postsByLocation[newLocationKey] = [post];
        AppLogger.log('🔄 Post ${post.id} created new location group: $newLocationKey');
      }

      processedPosts.add(post.id);
    }

    AppLogger.log('🔄 Grouped posts into ${postsByLocation.length} locations');
    AppLogger.log('⭐⭐⭐ ИТОГИ ГРУППИРОВКИ ПОСТОВ ⭐⭐⭐');
    postsByLocation.forEach((key, posts) {
      AppLogger.log('📍📍📍 Location $key has ${posts.length} posts: ${posts.map((p) => p.id).join(", ")} 📍📍📍');
    });

    // Сортируем локации по количеству уникальных пользователей в локации
    final List<MapEntry<String, List<Post>>> sortedLocationEntries = postsByLocation.entries.toList();
    sortedLocationEntries.sort((a, b) {
      // Считаем количество уникальных пользователей в каждой локации
      final Set<String> uniqueUsersA = a.value.map((p) => p.user).toSet();
      final Set<String> uniqueUsersB = b.value.map((p) => p.user).toSet();
      
      // Сначала сортируем по количеству уникальных пользователей (больше = выше)
      int uniqueUserComparison = uniqueUsersB.length.compareTo(uniqueUsersA.length);
      
      // Если количество уникальных пользователей одинаково, сортируем по дате новейшего поста
      if (uniqueUserComparison == 0) {
        final latestPostA = a.value.reduce((curr, next) => 
          curr.createdAt.isAfter(next.createdAt) ? curr : next);
        final latestPostB = b.value.reduce((curr, next) => 
          curr.createdAt.isAfter(next.createdAt) ? curr : next);
        return latestPostB.createdAt.compareTo(latestPostA.createdAt);
      }
      
      return uniqueUserComparison;
    });
    
    // Создаем список отображаемых виджетов
    final List<Widget> feedItems = [];
    AppLogger.log('⭐⭐⭐ СОЗДАЕМ ВИДЖЕТЫ ДЛЯ ОТОБРАЖЕНИЯ ПОСТОВ ⭐⭐⭐');

    for (var entry in sortedLocationEntries) {
      final postsInLocation = entry.value;

      if (postsInLocation.length > 1) {
        // Если больше одного поста в локации, используем LocationPostsViewer
        AppLogger.log('🎮🎮🎮 Creating LocationPostsViewer for ${postsInLocation.length} posts at ${entry.key}');
        AppLogger.log('📝📝📝 Post IDs: ${postsInLocation.map((p) => p.id).join(", ")} 📝📝📝');
        AppLogger.log('⭐⭐⭐ СОЗДАЕМ ГРУППУ ПОСТОВ ДЛЯ СВАЙПА! Количество: ${postsInLocation.length}, Локация: ${entry.key} ⭐⭐⭐');
        AppLogger.log('📍📍📍 Координаты постов: ${postsInLocation.map((p) => "${p.location.latitude},${p.location.longitude}").join(" | ")} 📍📍📍');
        
        // Добавляем элемент с LocationPostsViewer
        feedItems.add(
          FutureBuilder<Map<String, bool>>(
            future: _getFollowingStatusForUsers(postsInLocation.map((p) => p.user).toSet().toList()),
            builder: (context, snapshot) {
              final followingUsers = snapshot.data ?? {};

              return LocationPostsViewer(
                initialPost: postsInLocation.first,
                userProfileImage: _userProfileImage,
                userFullName: _userFullName,
                onShowCommentsModal: _showCommentsModal,
                onShowOnMap: _showOnMap,
                onEditPost: _editPost,
                onDeletePost: _deletePost,
                onLikePost: _likePost,
                onFavoritePost: _favoritePost,
                onFollowUser: _followUser,
                followingUsers: followingUsers,
                onImageTap: _openImageViewer,
              );
            },
          ),
        );
      } else {
        // Если только один пост, используем обычную PostCard
        final post = postsInLocation.first;
        AppLogger.log('🔄 Creating regular PostCard for post ${post.id} at ${entry.key}');
        
        // Добавляем элемент с PostCard
        feedItems.add(
          FutureBuilder<Map<String, dynamic>>(
            future: _getPostAuthorInfo(post),
            builder: (context, authorSnapshot) {
              final authorInfo = authorSnapshot.data ?? {'firstName': 'Loading...', 'lastName': '', 'profileImageUrl': ''};
              final authorName = '${authorInfo['firstName']} ${authorInfo['lastName']}';
              final authorProfileImage = authorInfo['profileImageUrl'] as String?;
              
              return FutureBuilder<bool>(
                future: _checkIsFollowing(post.user),
                builder: (context, snapshot) {
                  final isFollowing = snapshot.data ?? false;

                  return Container(
                    margin: EdgeInsets.symmetric(vertical: 8),
                    decoration: BoxDecoration(
                      // Добавляем подсветку, если это пост, который в данный момент выбран
                      border: _lastViewedPostIndex == _posts.indexWhere((p) => p.id == post.id)
                        ? Border.all(color: Colors.blue, width: 3)
                        : null,
                      borderRadius: BorderRadius.circular(12),
                      boxShadow: _lastViewedPostIndex == _posts.indexWhere((p) => p.id == post.id)
                        ? [
                            BoxShadow(
                              color: Colors.blue.withOpacity(0.3),
                              blurRadius: 10,
                              spreadRadius: 3,
                            )
                          ]
                        : [
                            BoxShadow(
                              color: Colors.black.withOpacity(0.1),
                              blurRadius: 5,
                              spreadRadius: 1,
                            )
                          ],
                    ),
                    child: PostCard(
                      post: post,
                      userProfileImage: _userProfileImage,
                      userFullName: _userFullName,
                      authorProfileImage: authorProfileImage,
                      authorName: authorName,
                      onShowCommentsModal: _showCommentsModal,
                      onShowOnMap: _showOnMap,
                      onEditPost: _editPost,
                      onDeletePost: _deletePost,
                      isCurrentUserPost: _isCurrentUserPost(post),
                      onLikePost: _likePost,
                      onFavoritePost: _favoritePost,
                      onFollowUser: _followUser,
                      isFollowing: isFollowing,
                      onImageTap: _openImageViewer,
                    ),
                  );
                },
              );
            },
          ),
        );
      }
    }

    AppLogger.log('🎉🎉🎉 ГОТОВО! Создано ${feedItems.length} элементов ленты 🎉🎉🎉');

    // Отображаем элементы ленты в простом ListView с минимальными отступами
    return ListView.separated(
      controller: _feedScrollController,
      physics: ClampingScrollPhysics(),
      padding: EdgeInsets.symmetric(horizontal: 8, vertical: 4),
      itemCount: feedItems.length,
      separatorBuilder: (context, index) => SizedBox(height: 4),
      itemBuilder: (context, index) {
        return feedItems[index];
      },
    );
  }

  // Получаем статус подписки для нескольких пользователей
  Future<Map<String, bool>> _getFollowingStatusForUsers(List<String> userIds) async {
    final Map<String, bool> result = {};

    for (var userId in userIds) {
      try {
        if (_userEmail == userId || _userId == userId || userId == 'current_user') {
          result[userId] = false;
        } else {
          result[userId] = await SocialService.isFollowing(userId);
        }
      } catch (e) {
        AppLogger.log("Error checking following status for $userId: $e");
        result[userId] = false;
      }
    }

    return result;
  }

  // Проверяем, является ли пост текущего пользователя
  bool _isCurrentUserPost(Post post) {
    // Проверяем наличие идентификаторов пользователя
    if (_userEmail.isEmpty && _userId.isEmpty) {
      AppLogger.log("❌ HomeTab _isCurrentUserPost: Нет доступных идентификаторов пользователя, возвращаем false");
      return false;
    }

    // Сначала проверяем, совпадает ли пользователь поста с email текущего пользователя
    if (post.user == _userEmail) {
      return true;
    }

    // Если у нас есть числовой идентификатор пользователя, проверяем, совпадает ли post.user с ним
    if (_userId.isNotEmpty && post.user == _userId) {
      return true;
    }

    // Пытаемся проверить, является ли пользователь поста числовым ID
    try {
      final int? postUserId = int.tryParse(post.user);
      final int? currentUserId = int.tryParse(_userId);

      if (postUserId != null && currentUserId != null && postUserId == currentUserId) {
        return true;
      }
    } catch (e) {
      // Ошибка парсинга, может означать, что post.user не является числовым ID
    }

    // Наконец, проверяем специальные значения, которые могут представлять текущего пользователя
    if (post.user == 'current_user' || post.user == 'null') {
      return true;
    }

    return false;
  }

  // Проверяем, подписан ли пользователь на автора поста
  Future<bool> _checkIsFollowing(String userId) async {
    try {
      if (_userEmail == userId || _userId == userId || userId == 'current_user') {
        return false; // Нельзя подписаться на самого себя
      }
      return await SocialService.isFollowing(userId);
    } catch (e) {
      AppLogger.log("Error checking following status: $e");
      return false;
    }
  }

  // Обработчик лайка поста
  Future<void> _likePost(Post post) async {
    try {
      final isLiked = await SocialService.isLiked(post.id);

      if (isLiked) {
        await SocialService.unlikePost(post.id);
      } else {
        await SocialService.likePost(post.id);
      }

      // Обновляем UI
      setState(() {});
    } catch (e) {
      AppLogger.log("Error liking post: $e");
    }
  }

  // Обработчик добавления/удаления из избранного
  Future<void> _favoritePost(Post post) async {
    try {
      final isFavorite = await SocialService.isFavorite(post.id);

      if (isFavorite) {
        await SocialService.removeFromFavorites(post.id);
      } else {
        await SocialService.addToFavorites(post.id);
      }

      // Обновляем UI
      setState(() {});
    } catch (e) {
      AppLogger.log("Error favoriting post: $e");
    }
  }

  // Обработчик подписки на пользователя
  Future<void> _followUser(String userId) async {
    try {
      // Проверяем, не пытается ли пользователь подписаться на самого себя
      if (_userEmail == userId || _userId == userId || userId == 'current_user') {
        AppLogger.log("Попытка подписаться на самого себя: $_userEmail/$_userId. Операция отменена.");
        return;
      }

      final isFollowing = await SocialService.isFollowing(userId);

      if (isFollowing) {
        await SocialService.unfollowUser(userId);
      } else {
        await SocialService.followUser(userId);
      }

      // Обновляем UI
      setState(() {});
    } catch (e) {
      AppLogger.log("Error following user: $e");
    }
  }

  // Метод для прокрутки к нужному посту в ленте
  void _scrollToPostInFeed(Post post) {
    // Находим индекс поста в списке
    int postIndex = _posts.indexWhere((p) => p.id == post.id);

    if (postIndex != -1 && _feedScrollController.hasClients) {
      // Расчетная высота одного поста (примерно)
      double approximatePostHeight = 350.0; // может потребоваться корректировка

      // Прокручиваем к позиции поста
      _feedScrollController.animateTo(
        postIndex * approximatePostHeight,
        duration: const Duration(milliseconds: 500),
        curve: Curves.easeInOut,
      );

      // Анимируем подсветку поста после прокрутки
      // (этот код можно будет реализовать позже)
    }
  }

  // Открытие просмотрщика изображений на весь экран
  void _openImageViewer(Post post, int initialIndex) {
    AppLogger.log('⭐⭐⭐ HomeTab._openImageViewer ВЫЗВАН для поста ${post.id}, initialIndex=${initialIndex} ⭐⭐⭐');
    AppLogger.log('🔍🔍🔍 POST LOCATION: ${post.locationName}, COORDINATES: ${post.location.latitude},${post.location.longitude} 🔍🔍🔍');

    // Проверяем, что пост и изображения существуют
    if (post == null || (post.imageUrls.isEmpty && post.images.isEmpty)) {
      ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Нет доступных изображений для просмотра'))
      );
      return;
    }

    if (post.imageUrls.isNotEmpty) {
      // Если есть URL изображений, открываем просмотрщик сетевых изображений
      AppLogger.log('🔍 HomeTab: Opening NetworkImageViewerScreen for post ${post.id}');
      AppLogger.log('📷📷📷 Открываем NetworkImageViewerScreen для поста ${post.id} с ${post.imageUrls.length} изображениями 📷📷📷');
      AppLogger.log('📝📝📝 Первый URL изображения: ${post.imageUrls.first} 📝📝📝');

      Navigator.push(
        context,
        MaterialPageRoute(
          builder: (context) => NetworkImageViewerScreen(
            imageUrls: post.imageUrls,
            initialIndex: initialIndex < post.imageUrls.length ? initialIndex : 0,
            parentPost: post, // Передаем родительский пост для поддержки свайпа
          ),
        ),
      );
    } else if (post.images.isNotEmpty) {
      // Если есть локальные изображения, открываем просмотрщик файлов
      AppLogger.log('📱📱📱 Открываем ImageViewerScreen для локальных изображений поста ${post.id} 📱📱📱');
      Navigator.push(
        context,
        MaterialPageRoute(
          builder: (context) => ImageViewerScreen(
            images: post.images,
            initialIndex: initialIndex < post.images.length ? initialIndex : 0,
          ),
        ),
      );
    }
  }

  // Метод для отслеживания скролла в ленте и определения текущего видимого поста
  void _onFeedScroll() {
    if (!_feedScrollController.hasClients || _posts.isEmpty) return;

    // Определяем текущую позицию скролла
    final double scrollOffset = _feedScrollController.offset;

    // Примерная высота поста (может потребоваться корректировка)
    double approximatePostHeight = 350.0;

    // Вычисляем примерный индекс видимого поста
    int visiblePostIndex = (scrollOffset / approximatePostHeight).floor();

    // Проверяем границы
    if (visiblePostIndex < 0) visiblePostIndex = 0;
    if (visiblePostIndex >= _posts.length) visiblePostIndex = _posts.length - 1;

    // Сохраняем информацию о текущем видимом посте
    _lastViewedPost = _posts[visiblePostIndex];
    _lastViewedPostIndex = visiblePostIndex;
  }

  Map<String, List<Post>> _groupPostsByLocation(List<Post> posts) {
    AppLogger.log('🔴🔴🔴 МЕТОД _groupPostsByLocation ВЫЗВАН С ${posts.length} ПОСТАМИ 🔴🔴🔴');
    AppLogger.log('🔍 Группируем посты по локациям...');
    final Map<String, List<Post>> postsByLocation = {};

    // Сначала группируем посты по имени локации
    for (var post in posts) {
      final locationName = post.locationName.toLowerCase();

      if (postsByLocation.containsKey(locationName)) {
        postsByLocation[locationName]!.add(post);
      } else {
        postsByLocation[locationName] = [post];
      }
    }

    AppLogger.log('🔄 Grouped posts into ${postsByLocation.length} locations');
    AppLogger.log('🔴🔴🔴 ИТОГИ ГРУППИРОВКИ ПОСТОВ 🔴🔴🔴');
    postsByLocation.forEach((key, posts) {
      AppLogger.log('📍📍📍 Location $key has ${posts.length} posts: ${posts.map((p) => p.id).join(", ")} 📍📍📍');

      // Добавляем информацию о расстоянии между постами в одной локации
      if (posts.length > 1) {
        AppLogger.log('🌍🌍🌍 РАССТОЯНИЯ МЕЖДУ ПОСТАМИ В ЛОКАЦИИ "$key" 🌍🌍🌍');
        for (int i = 0; i < posts.length; i++) {
          for (int j = i + 1; j < posts.length; j++) {
            final distance = _calculateDistanceBetweenPosts(posts[i], posts[j]);
            AppLogger.log('🔢 Расстояние между постами ${posts[i].id} и ${posts[j].id}: ${distance.toStringAsFixed(2)} метров');
          }
        }
      }
    });

    // Сортируем локации по дате создания самого нового поста
    final List<MapEntry<String, List<Post>>> sortedLocationEntries = postsByLocation.entries.toList();
    sortedLocationEntries.sort((a, b) {
      final latestPostA = a.value.reduce((curr, next) =>
      curr.createdAt.isAfter(next.createdAt) ? curr : next);
      final latestPostB = b.value.reduce((curr, next) =>
      curr.createdAt.isAfter(next.createdAt) ? curr : next);
      return latestPostB.createdAt.compareTo(latestPostA.createdAt);
    });

    return postsByLocation;
  }

  // Вспомогательный метод для расчета расстояния между постами
  double _calculateDistanceBetweenPosts(Post post1, Post post2) {
    return _calculateDistance(
        post1.location.latitude, post1.location.longitude,
        post2.location.latitude, post2.location.longitude
    );
  }

  // Вспомогательный метод для расчета расстояния между координатами в метрах
  double _calculateDistance(double lat1, double lon1, double lat2, double lon2) {
    const int earthRadius = 6371000; // радиус Земли в метрах

    // Перевод градусов в радианы
    final double phi1 = lat1 * 3.14159265359 / 180;
    final double phi2 = lat2 * 3.14159265359 / 180;
    final double deltaPhi = (lat2 - lat1) * 3.14159265359 / 180;
    final double deltaLambda = (lon2 - lon1) * 3.14159265359 / 180;

    // Формула гаверсинусов
    final double a = sin(deltaPhi / 2) * sin(deltaPhi / 2) +
        cos(phi1) * cos(phi2) *
            sin(deltaLambda / 2) * sin(deltaLambda / 2);
    final double c = 2 * atan2(sqrt(a), sqrt(1 - a));

    return earthRadius * c; // Расстояние в метрах
  }

  // Reload markers with current filter settings
  Future<void> _reloadMarkers() async {
    if (_mapboxMap == null) {
      AppLogger.log("Can't reload markers: map is null");
      return;
    }
    
    if (!_isMapLoaded) {
      AppLogger.log("Can't reload markers: map is not loaded");
      return;
    }
    
    AppLogger.log("Reloading markers with filter: showOnlyFavorites=$_showOnlyFavorites");
    
    setState(() {
      _markersLoading = true;
    });
    
    try {
      // Создаем новый менеджер аннотаций (вместо очистки)
      final annotations = await _mapboxMap!.annotations;
      
      // В версии Mapbox 2.6.2 нет метода removeOnPointAnnotationClickListener,
      // поэтому просто создаем новый менеджер, что автоматически отвяжет старый
      _pointAnnotationManager = null;
      
      // Создаем новый менеджер аннотаций
      _pointAnnotationManager = await annotations.createPointAnnotationManager();
      _pointAnnotationManager?.addOnPointAnnotationClickListener(_markerClickListener);
      
      // Очищаем карту маркеров
      _markerPostMap = {};
      
      // Apply filters based on current settings
      List<Post> filteredPosts = List.from(_posts); // Create a copy
      
      // Filter posts to only show favorites if needed
      if (_showOnlyFavorites) {
        AppLogger.log("Getting favorite posts for filtering...");
        // Get favorite posts
        final favoritePosts = await SocialService.getFavoritePosts();
        AppLogger.log("Got ${favoritePosts.length} favorite posts");
        
        final favoriteIds = favoritePosts.map((post) => post.id).toSet();
        AppLogger.log("Favorite IDs: $favoriteIds");
        
        // Filter the posts
        filteredPosts = filteredPosts.where((post) => favoriteIds.contains(post.id)).toList();
        
        AppLogger.log("Filtered to ${filteredPosts.length} favorite posts from ${_posts.length} total posts");
        
        // Выводим ID отфильтрованных постов для отладки
        for (var post in filteredPosts) {
          AppLogger.log("Filtered post ID: ${post.id}");
        }
      }
      
      // Add filtered markers to the map
      if (filteredPosts.isEmpty) {
        AppLogger.log("No posts to display after filtering");
      } else {
        await _addPostMarkersToMap(filteredPosts);
      }
      
      setState(() {
        _markersLoading = false;
      });
    } catch (e) {
      AppLogger.log("Error reloading markers: $e");
      setState(() {
        _markersLoading = false;
        _error = e.toString();
      });
    }
  }
  
  // Обработчик изменения фильтра
  void _handleFilterChange(bool showOnlyFavorites) {
    AppLogger.log("Filter changed: showOnlyFavorites=$showOnlyFavorites");
    
    setState(() {
      _showOnlyFavorites = showOnlyFavorites;
      
      // Если включен фильтр избранных, переключаемся на вид карты
      if (showOnlyFavorites && _activeView != 'map') {
        _activeView = 'map';
      }
    });
    
    // Перезагружаем маркеры на карте только если карта уже загружена
    if (_isMapLoaded) {
      Future.microtask(() => _reloadMarkers());
    }
  }
  
  // ... existing code ...
  
  // Метод для добавления всех маркеров постов на карту
  Future<void> _addPostMarkersToMap(List<Post> posts) async {
    if (_mapboxMap == null) {
      AppLogger.log("Can't add markers: map is null");
      return;
    }
    
    // Инициализируем менеджер аннотаций, если он еще не создан
    if (_pointAnnotationManager == null) {
      try {
        final annotations = await _mapboxMap!.annotations;
        _pointAnnotationManager = await annotations.createPointAnnotationManager();
        AppLogger.log("Created new point annotation manager for markers");
      } catch (e) {
        AppLogger.log("Error creating point annotation manager: $e");
        return;
      }
    }
    
    try {
      int markersAdded = 0;
      
      // Проходим по всем постам и создаем маркеры только для тех, у которых есть геолокация
      for (final post in posts) {
        // Пропускаем посты без местоположения
        if (post.location == null || 
            (post.location.latitude == 0 && post.location.longitude == 0)) {
          AppLogger.log("Skipping post ${post.id} - no valid location");
          continue;
        }
        
        AppLogger.log("Creating marker for post ${post.id} at ${post.location.latitude},${post.location.longitude}");
        
        // Настройки маркера
        String markerImageId = "marker-15"; // Используем стандартный маркер по умолчанию
        double iconSize = 0.3; // Стандартный размер (уменьшен в 2 раза)
        bool hasImage = false;
        
        // Если у поста есть изображения, используем одно из них для маркера
        if (post.imageUrls.isNotEmpty) {
          try {
            // ВАЖНО: проверяем, есть ли изображение в кэше по ID
            final String cacheId = "post-marker-${post.id}";
            
            if (MapboxConfig.markerImageBytesCache.containsKey(cacheId)) {
              AppLogger.log("✅ Using cached image for marker: $cacheId");
              hasImage = true;
              markerImageId = cacheId;
            } else {
              // Берем первое доступное изображение
              String imageUrl = post.imageUrls.first;
              
              // При необходимости корректируем URL
              if (!imageUrl.startsWith("http")) {
                if (imageUrl.startsWith("/")) {
                  imageUrl = imageUrl.substring(1);
                }
                imageUrl = "${ApiConfig.baseUrl}/${imageUrl}";
              }
              
              AppLogger.log("Using image URL: $imageUrl");
              final http.Response response = await http.get(Uri.parse(imageUrl));
              
              if (response.statusCode == 200) {
                final Uint8List imageBytes = response.bodyBytes;
                
                // Регистрируем изображение как маркер
                markerImageId = await MapboxConfig.registerPostImageAsMarker(
                  _mapboxMap!,
                  imageBytes,
                  post.id
                );
                
                hasImage = true;
              } else {
                AppLogger.log("Failed to load image from URL: ${response.statusCode}");
              }
            }
          } catch (e) {
            AppLogger.log("Error loading image for marker: $e");
            // Продолжаем с стандартным маркером
          }
        }
        
        try {
          // Создаем опции для маркера
          final PointAnnotationOptions options = PointAnnotationOptions(
            geometry: Point(
              coordinates: Position(
                post.location.longitude,
                post.location.latitude,
              ),
            ),
            iconImage: hasImage ? markerImageId : "marker-15", // Используем ID зарегистрированного изображения или стандартный маркер
            iconSize: iconSize,
            iconAnchor: IconAnchor.BOTTOM,
            textField: post.locationName,
            textSize: 12.0,
            textOffset: [0.0, 2.0],
            textColor: Colors.black.value,
            textHaloColor: Colors.white.value,
            textHaloWidth: 2.0,
            iconOffset: [0.0, 0.0],
            symbolSortKey: 1.0,
            iconOpacity: 1.0,
          );
          
          // Добавляем маркер на карту
          final annotation = await _pointAnnotationManager?.create(options);
          if (annotation != null) {
            _markerPostMap[annotation.id] = post;
            markersAdded++;
            AppLogger.log("Added marker with ID: ${annotation.id} for post ${post.id}");
          } else {
            AppLogger.log("Failed to create marker for post ${post.id}");
          }
        } catch (e) {
          AppLogger.log("Ошибка при создании маркера для поста ${post.id}: $e");
          // Продолжаем с следующим постом
          continue;
        }
      }
      
      AppLogger.log("Добавлено $markersAdded маркеров из ${posts.length} постов");
    } catch (e) {
      AppLogger.log("Ошибка при добавлении маркеров постов на карту: $e");
    }
  }
  
  // Метод для очистки всех маркеров с карты
  Future<void> _clearAllMarkers() async {
    if (_pointAnnotationManager == null) {
      AppLogger.log("Невозможно очистить маркеры: менеджер аннотаций не инициализирован");
      return;
    }
    
    try {
      // Предварительно очищаем карту маркеров
      _markerPostMap = {};
      
      // Безопасная проверка перед удалением
      final annotations = await _mapboxMap?.annotations;
      if (annotations == null) {
        AppLogger.log("Невозможно получить доступ к аннотациям карты");
        return;
      }
      
      // Вместо удаления всех маркеров через deleteAll(), создаем новый менеджер
      _pointAnnotationManager = await annotations.createPointAnnotationManager();
      _pointAnnotationManager?.addOnPointAnnotationClickListener(_markerClickListener);
      
      AppLogger.log("Маркеры успешно очищены");
    } catch (e) {
      AppLogger.log("Ошибка при очистке маркеров: $e");
    }
  }

  // Загружаем сохраненные настройки камеры из SharedPreferences
  Future<void> _loadSavedCameraOptions() async {
    try {
      final prefs = await SharedPreferences.getInstance();

      // Получаем сохраненные значения
      final double? savedZoom = prefs.getDouble('camera_zoom');
      final double? savedLat = prefs.getDouble('camera_lat');
      final double? savedLng = prefs.getDouble('camera_lng');

      // Если есть сохраненные значения, создаем CameraOptions
      if (savedZoom != null && savedLat != null && savedLng != null) {
        _lastCameraOptions = CameraOptions(
          center: Point(
            coordinates: Position(savedLng, savedLat),
          ),
          zoom: savedZoom,
        );
        AppLogger.log("Загружены сохраненные настройки камеры: center=$savedLng,$savedLat zoom=$savedZoom");
      } else {
        AppLogger.log("Нет сохраненных настроек камеры");
      }
    } catch (e) {
      AppLogger.log("Ошибка при загрузке настроек камеры: $e");
    }
  }

  // Сохраняем настройки камеры в SharedPreferences
  Future<void> _saveCameraOptions() async {
    if (_lastCameraOptions == null) return;

    try {
      final prefs = await SharedPreferences.getInstance();

      // Получаем значения из CameraOptions
      final double zoom = _lastCameraOptions!.zoom ?? 12.0;
      final double lat = (_lastCameraOptions!.center?.coordinates.lat ?? 0.0).toDouble();
      final double lng = (_lastCameraOptions!.center?.coordinates.lng ?? 0.0).toDouble();

      // Сохраняем значения
      await prefs.setDouble('camera_zoom', zoom);
      await prefs.setDouble('camera_lat', lat);
      await prefs.setDouble('camera_lng', lng);

      AppLogger.log("Настройки камеры сохранены: center=$lng,$lat zoom=$zoom");
    } catch (e) {
      AppLogger.log("Ошибка при сохранении настроек камеры: $e");
    }
  }

  // Вспомогательный метод для обновления настроек камеры
  Future<void> _updateCameraOptions() async {
    try {
    if (_mapboxMap != null) {
        final CameraState cameraState = await _mapboxMap!.getCameraState();

        // Только обновляем настройки, если они действительно изменились
        final newZoom = cameraState.zoom;
        final oldZoom = _lastCameraOptions?.zoom;

        if (_lastCameraOptions == null ||
            newZoom != oldZoom ||
            cameraState.center != _lastCameraOptions?.center) {

          _lastCameraOptions = CameraOptions(
              center: cameraState.center,
              zoom: cameraState.zoom,
              bearing: cameraState.bearing,
              pitch: cameraState.pitch
          );

          AppLogger.log("Обновлены настройки камеры: center=${cameraState.center.coordinates.lng},${cameraState.center.coordinates.lat} zoom=${newZoom}");

          // Сохраняем обновленные настройки
          _saveCameraOptions();
        }
      }
    } catch (e) {
      AppLogger.log("Ошибка при обновлении настроек камеры: $e");
    }
  }


  // Modify the marker loading function to use the filtered posts
  Future<void> _loadMarkersIfNeeded() async {
    if (_mapboxMap == null || !_isMapLoaded || _markersLoading) {
      AppLogger.log("Невозможно загрузить маркеры: карта не готова или загрузка уже идет");
      return;
    }
    
    // Проверяем флаг _showingSpecificPost
    if (_showingSpecificPost) {
      AppLogger.log("⚠️ Пропускаем загрузку маркеров, так как показывается конкретный пост");
      return;
    }
    
    setState(() {
      _markersLoading = true;
    });
    
    try {
      // Проверяем состояние и создаем новый менеджер аннотаций, если необходимо
      if (_pointAnnotationManager == null) {
        final annotations = await _mapboxMap!.annotations;
        _pointAnnotationManager = await annotations.createPointAnnotationManager();
        _pointAnnotationManager?.addOnPointAnnotationClickListener(_markerClickListener);
        AppLogger.log("PointAnnotationManager создан");
      } else {
        AppLogger.log("Используем существующий PointAnnotationManager");
      }
      
      // Добавляем маркеры с учетом текущих настроек фильтрации
      await _reloadMarkers();
    } catch (e) {
      AppLogger.log("Ошибка при загрузке маркеров: $e");
      setState(() {
        _markersLoading = false;
        _error = e.toString();
      });
    }
  }

  // Метод для выделения кликнутого маркера
  Future<void> _highlightClickedMarker(String markerId) async {
    // Check locks and map state first
    if (_isProcessingAnnotations) { /* ... log and return ... */ return; }
    if (_mapboxMap == null || !_isMapLoaded) { /* ... log and return ... */ return; }

    // Set lock
    if (mounted) _isProcessingAnnotations = true;

    // Find the target post using the current _markerPostMap *before* recreating the manager
    final Post? targetPost = _markerPostMap[markerId]; 
    if (targetPost == null) {
        AppLogger.log("⚠️ Не найден пост для маркера с ID: $markerId (highlight)");
        if (mounted) _isProcessingAnnotations = false; // Release lock
        return;
    }
    // Keep a copy of the current markers map to rebuild from
    final Map<String, Post> currentMarkerMapCopy = Map.from(_markerPostMap);

    try {
      AppLogger.log("🔍 Выделение маркера с ID: $markerId for post ${targetPost.id}");
      
      // --- Replace deleteAll with manager recreation ---
      try {
          AppLogger.log("🔄 Recreating annotation manager instead of deleteAll in _highlightClickedMarker");
          final annotations = await _mapboxMap!.annotations;
          _pointAnnotationManager = await annotations.createPointAnnotationManager();
          // Re-add listener to the new manager
          _pointAnnotationManager?.addOnPointAnnotationClickListener(_markerClickListener);
          AppLogger.log("✅ New annotation manager created in _highlightClickedMarker");
          _markerPostMap = {}; // Clear the Dart-side map, will rebuild below
      } catch (e) {
          AppLogger.log("❌ Error recreating annotation manager in _highlightClickedMarker: $e");
          if (mounted) _isProcessingAnnotations = false; // Release lock on error
          return; // Exit if we can't get a manager
      }
      // --- End of replacement ---
      
      // Создаем новую карту для обновленных соответствий маркеров и постов (not needed, cleared above)
      // final Map<String, Post> newMarkerPostMap = {}; <--- Remove this line
      int createdMarkers = 0;
      
      // Заново создаем все маркеры с учетом выделения, iterating over the *copy* of the old map
      for (var entry in currentMarkerMapCopy.entries) {
        final post = entry.value;
        
        // Создаем точку для маркера
        final point = Point(
          coordinates: Position(
            post.location!.longitude, 
            post.location!.latitude
          )
        );
        
        // Настройки маркера с учетом выделения
        final bool isTarget = (post.id == targetPost.id);
        if (isTarget) {
          AppLogger.log("🎯 Создаем выделенный маркер для поста ${post.id}");
        }
        
        final String markerImageId = "post-marker-${post.id}";
        final bool hasImage = await _mapboxMap!.style.hasStyleImage(markerImageId);
        
        var options = PointAnnotationOptions(
          geometry: point,
          iconSize: isTarget ? 0.6 : 0.3, // Увеличенный размер для целевого маркера
          iconImage: hasImage ? markerImageId : "marker-15", // Используем ID зарегистрированного изображения или стандартный маркер
          textField: post.locationName,
          textSize: isTarget ? 14.0 : 12.0, // Увеличенный размер текста для целевого маркера
          textOffset: [0, 3.0],
          textColor: 0xFF000000,
          textHaloColor: 0xFFFFFFFF,
          textHaloWidth: 2.0,
          iconOffset: [0, 0],
        );
        
        // Создаем маркер
        try {
        final annotation = await _pointAnnotationManager!.create(options);
        
        // Обновляем соответствие маркеров и постов
        if (annotation != null) {
            _markerPostMap[annotation.id] = post; // Add to the new map
            createdMarkers++;
          }
        } catch (e) {
          AppLogger.log("❌ Ошибка создания маркера для поста ${post.id}: $e");
        }
      }
      
      AppLogger.log("✅ Создано $createdMarkers маркеров после выделения");
      
      // Обновляем карту маркеров (already done by adding to _markerPostMap above)
      // _markerPostMap = newMarkerPostMap; // <--- Remove this line
      
      // Добавляем обработчик для новых маркеров (already done when manager was recreated)
      // _addMarkerClickListener(); // <--- Remove this line

    } catch (e) {
      AppLogger.log("❌ Ошибка при выделении кликнутого маркера: $e");
    } finally {
       // Release lock flag
       if (mounted) {
          _isProcessingAnnotations = false;
       }
       AppLogger.log("🏁 Завершение _highlightClickedMarker, флаг сброшен");
    }
  }

  // Метод для сброса выделенного поста
  void _resetHighlightedPost() {
    if (_lastViewedPost != null) {
      AppLogger.log("Сбрасываем выделение поста ${_lastViewedPost!.id}");
      _lastViewedPost = null;
      
      // Устанавливаем флаг, чтобы предотвратить вмешательство других методов
      _showingSpecificPost = false;
      
      // Перезагружаем маркеры без выделения
      _loadPostMarkers();
    }
  }
  
  // Обработчик нажатия кнопки назад на странице карты
  void _handleMapBackButton() {
    _resetHighlightedPost();
    setState(() {
      _activeView = 'feed';
    });
  }

