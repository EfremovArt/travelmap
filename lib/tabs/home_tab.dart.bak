  }

  @override
  void setState(VoidCallback fn) {
    if (mounted) {
      super.setState(fn);
      
      // Обрабатываем отложенные действия после обновления состояния
      if (_hasPendingAction) {
        WidgetsBinding.instance.addPostFrameCallback((_) {
          _processPendingActions();
        });
      }
    }
  }

  // Метод для добавления слоя с текущей локацией пользователя
  void _addUserLocationLayer() {
    if (_mapboxMap == null || _currentPosition == null) return;
    
    try {
      AppLogger.log('Добавление слоя текущего местоположения пользователя: ${_currentPosition!.latitude}, ${_currentPosition!.longitude}');
      
      // Тут можно было бы добавить пульсирующую точку или специальный маркер
      // для текущего местоположения пользователя, но для простоты просто
      // используем существующий метод перемещения камеры
      _moveCamera(_currentPosition!);
    } catch (e) {
      AppLogger.log('Ошибка при добавлении слоя местоположения пользователя: $e');
    }
  }

  // Добавляем новый метод для плавного перемещения камеры с анимацией
  Future<void> _flyToLocation(GeoLocation location) async {
    if (_mapboxMap == null) {
      AppLogger.log('❌ _flyToLocation: Карта не инициализирована');
      return;
    }
    
    if (!_isMapLoaded) {
      AppLogger.log('❌ _flyToLocation: Карта не загружена');
      return;
    }
    
    AppLogger.log('🔄 _flyToLocation: Перемещение камеры к координатам ${location.latitude}, ${location.longitude}');
    
    try {
      // Проверяем текущий стиль карты
      bool styleLoaded = await _mapboxMap!.style.isStyleLoaded();
      if (!styleLoaded) {
        AppLogger.log('⚠️ _flyToLocation: Стиль карты не загружен, ожидание загрузки...');
        // Ждем загрузки стиля
        await Future.delayed(Duration(milliseconds: 500));
      }
      
      // Получаем текущие настройки камеры
      CameraState? currentCameraState;
      try {
        currentCameraState = await _mapboxMap!.getCameraState();
        AppLogger.log('✅ _flyToLocation: Получены текущие настройки камеры: zoom=${currentCameraState.zoom}');
      } catch (e) {
        AppLogger.log('⚠️ _flyToLocation: Ошибка получения текущих настроек камеры: $e');
      }
      
      // Используем сохраненный зум, текущий зум или значение по умолчанию
      double zoom = currentCameraState?.zoom ?? _lastCameraOptions?.zoom ?? 14.0;
      
      // Создаем опции камеры
      final cameraOptions = CameraOptions(
        center: Point(
          coordinates: Position(
            location.longitude,
            location.latitude
          )
        ),
        zoom: zoom,
        bearing: 0.0,
        pitch: 0.0
      );
      
      AppLogger.log('🔄 _flyToLocation: Применяем анимированное перемещение камеры с zoom=$zoom');
      
      // Применяем анимированное перемещение камеры
      await _mapboxMap!.flyTo(
        cameraOptions,
        MapAnimationOptions(duration: 1500) // 1.5 секунды на анимацию
      );
      
      // Добавляем небольшую задержку для завершения анимации
      await Future.delayed(Duration(milliseconds: 100));
      
      // Сохраняем новые настройки камеры
      _lastCameraOptions = cameraOptions;
      
      AppLogger.log('✅ _flyToLocation: Камера перемещена с анимацией к позиции: ${location.latitude}, ${location.longitude}, zoom: $zoom');
    } catch (e) {
      AppLogger.log('❌ _flyToLocation: Ошибка анимированного перемещения камеры: $e');
      
      // Если не удалось использовать анимацию, используем обычное перемещение
      try {
        AppLogger.log('🔄 _flyToLocation: Пробуем обычное перемещение камеры');
        await _moveCamera(location);
      } catch (e2) {
        AppLogger.log('❌ _flyToLocation: Ошибка обычного перемещения камеры: $e2');
      }
    }
  }

  // Публичный метод для проверки наличия отложенных действий
  bool hasPendingAction() {
    return _hasPendingAction;
  }
  
  // Публичный метод для обработки отложенных действий
  void processPendingActions() {
    AppLogger.log('🔄 Публичный вызов processPendingActions()');
    _processPendingActions();
  }

  // Обработчик события отсутствующего изображения в стиле карты
  void _onStyleImageMissing(StyleImageMissingEvent event) {
    if (_mapboxMap == null) return;
    
    String imageId = event.id;
    AppLogger.log("🔄 Style image missing event: $imageId");
    
    // Проверяем, является ли это изображение маркером
    if (imageId.startsWith('post-marker-')) {
      try {
        // Извлекаем ID поста из ID изображения
        String postId = imageId.replaceFirst('post-marker-', '');
        AppLogger.log("🔍 Looking for cached marker image: $imageId (post ID: $postId)");
        
        // Проверяем наличие изображения в кэше
        if (MapboxConfig.markerImageBytesCache.containsKey(imageId)) {
          try {
            // Получаем закэшированные данные
            final imageBytes = MapboxConfig.markerImageBytesCache[imageId]!;
            final width = MapboxConfig.markerImageSizeCache[imageId]?.width ?? 64;
            final height = MapboxConfig.markerImageSizeCache[imageId]?.height ?? 64;
            
            // Создаем изображение и добавляем его в стиль
            final mbxImage = MbxImage(
              width: width,
              height: height,
              data: imageBytes,
            );
            
            // Добавляем изображение в стиль карты
            _mapboxMap!.style.addStyleImage(
              imageId,
              1.0,
              mbxImage,
              false,
              [],
              [],
              null
            );
            
            AppLogger.log("✅ Successfully restored cached marker image: $imageId");
          } catch (e) {
            AppLogger.log("❌ Error restoring cached marker image: $e");
          }
        } else {
          // Если изображения нет в кэше, попробуем загрузить его
          AppLogger.log("⚠️ No cached image found for $imageId, attempting to load it");
          _loadMissingMarkerImage(postId, imageId);
        }
      } catch (e) {
        AppLogger.log("❌ Error processing style image missing event: $e");
      }
    } else if (imageId == "marker-15" || imageId == "custom-marker") {
      // Обработка стандартных маркеров
      _loadDefaultMarkerImage(imageId);
    }
  }

  // Загрузка недостающего изображения маркера
  Future<void> _loadMissingMarkerImage(String postId, String imageId) async {
    try {
      AppLogger.log("🔄 Loading missing marker image for post: $postId");
      
      // Находим пост в текущем списке постов
      Post? post;
      try {
        post = _posts.firstWhere((p) => p.id == postId);
        AppLogger.log("✅ Found post in current list with ID: $postId");
      } catch (e) {
        AppLogger.log("⚠️ Post not found in current list, trying to load it: $postId");
        post = null;
      }
      
      // Если не нашли пост в списке, пытаемся загрузить его
      if (post == null) {
        try {
          post = await PostService.getPostById(postId);
          if (post != null) {
            AppLogger.log("✅ Successfully loaded post with ID: $postId");
          } else {
            AppLogger.log("❌ Failed to load post with ID: $postId");
            return;
          }
        } catch (e) {
          AppLogger.log("❌ Error loading post by ID: $e");
          return;
        }
      }
      
      // Если у поста есть изображения, используем первое из них
      if (post.imageUrls.isNotEmpty) {
        try {
          String imageUrl = post.imageUrls.first;
          
          // Корректируем URL если нужно
          if (!imageUrl.startsWith("http")) {
            if (imageUrl.startsWith("/")) {
              imageUrl = imageUrl.substring(1);
            }
            imageUrl = "${ApiConfig.baseUrl}/${imageUrl}";
          }
          
          AppLogger.log("🔍 Loading image from URL: $imageUrl");
          
          // Загружаем изображение
          final http.Response response = await http.get(Uri.parse(imageUrl));
          
          if (response.statusCode == 200 && _mapboxMap != null) {
            final Uint8List imageBytes = response.bodyBytes;
            
            // Регистрируем изображение как маркер
            await MapboxConfig.registerPostImageAsMarker(
              _mapboxMap!,
              imageBytes,
              postId
            );
            
            AppLogger.log("✅ Successfully loaded and registered marker image for post: $postId");
          } else {
            AppLogger.log("❌ Failed to load image, status: ${response.statusCode}");
          }
        } catch (e) {
          AppLogger.log("❌ Error loading image for post: $e");
        }
      } else {
        AppLogger.log("⚠️ Post has no images: $postId");
      }
    } catch (e) {
      AppLogger.log("❌ General error in _loadMissingMarkerImage: $e");
    }
  }
  
  // Загрузка стандартного изображения маркера
  Future<void> _loadDefaultMarkerImage(String imageId) async {
    try {
      AppLogger.log("🔄 Loading default marker image: $imageId");
      
      // Проверяем, уже зарегистрирован ли стандартный маркер
      bool existsInStyle = false;
      try {
        existsInStyle = await _mapboxMap!.style.hasStyleImage(imageId);
      } catch (e) {
        AppLogger.log("⚠️ Error checking style image: $e");
      }
      
      if (!existsInStyle) {
        // Загружаем стандартные маркеры карты
        try {
          await MapboxConfig.registerMapboxMarkerImages(_mapboxMap!);
          AppLogger.log("✅ Default markers registered successfully");
        } catch (e) {
          AppLogger.log("❌ Error registering default markers: $e");
        }
      } else {
        AppLogger.log("✅ Default marker already exists in style: $imageId");
      }
    } catch (e) {
      AppLogger.log("❌ Error in _loadDefaultMarkerImage: $e");
    }
  }
} 
